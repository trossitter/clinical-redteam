ANTHROPIC_API_KEY=sk-ant-...
TARGET_URL=https://clinicalcopilot.org/copilot
COPILOT_SECRET=your_secret_here

# Red Team provider: "ollama" (local dev) or "groq" (deployed)
RED_TEAM_PROVIDER=ollama

# Groq (used when RED_TEAM_PROVIDER=groq)
GROQ_API_KEY=gsk_...
RED_TEAM_MODEL=llama-3.3-70b-versatile

# Ollama (used when RED_TEAM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Judge / Orchestrator / Documentation
JUDGE_MODEL=claude-sonnet-4-6
ORCHESTRATOR_MODEL=claude-sonnet-4-6
DOC_MODEL=claude-sonnet-4-6

# Session limits
SESSION_BUDGET_TOKENS=100000
MAX_ITERATIONS=50
MAX_MUTATIONS=3

# Observability (optional — platform works without these)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
